# Standard .gitignore for SplitSmart (Microservices + Frontend)

# --- IDEs & OS ---
.idea/
*.iml
.vscode/
.project
.classpath
.settings/
bin/
.DS_Store
Thumbs.db
*.swp
*.bak

# --- Backend (Spring Boot / Maven) ---
**/target/
**/.mvn/
**/mvnw
**/mvnw.cmd
*.jar
*.war
*.ear
**/*.log
**/dbconfig.php (if any)

# --- Frontend (React / Next.js) ---
**/node_modules/
**/build/
**/.next/
**/out/
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Docker & Infrastructure ---
.docker/
**/mysql_data/
**/kafka_data/
**/zookeeper_data/

# --- Tools & Gemini ---
.gemini/
.agents/
/tmp/
brain/
walkthrough.md
task.md
implementation_plan.md
